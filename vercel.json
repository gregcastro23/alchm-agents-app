{
  "installCommand": "bun install",
  "buildCommand": "bun run prisma:generate && bun run build",
  "framework": "nextjs",
  "regions": ["iad1"],
  "git": {
    "deploymentEnabled": true
  },
  "build": {
    "env": {
      "NODE_ENV": "production",
      "NODE_VERSION": "20.x"
    }
  },
  "crons": [
    {
      "path": "/api/cron/agents/claim-yield",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/agents/tick",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/push-feed",
      "schedule": "*/30 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate"
        }
      ]
    }
  ]
}
