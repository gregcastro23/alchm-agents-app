   "source": [
    "# XP and Level Calculation System\n",
    "\nimport math\n\ndef calculate_level_from_xp(total_xp):\n",
    "    \"\"\"\n",
    "    Calculate AI level based on total XP using exponential curve\n",
    "    \"\"\"\n",
    "    if total_xp <= 0:\n",
    "        return 1\n",
    "    \n",
    "    # Exponential XP requirement: XP = 100 * (level^1.5)\n",
    "    level = math.floor((total_xp / 100) ** (2/3))\n",
    "    return max(1, min(100, level + 1))\n",
    "\ndef calculate_xp_for_level(level):\n",
    "    \"\"\"\n",
    "    Calculate XP required to reach a specific level\n",
    "    \"\"\"\n",
    "    return math.floor(100 * ((level - 1) ** 1.5))\n",
    "\ndef calculate_interaction_xp(interaction_quality, user_feedback, streak_multiplier=1):\n",
    "    \"\"\"\n",
    "    Calculate XP gained from a single interaction\n",
    "    \"\"\"\n",
    "    base_xp = {\n",
    "        'poor': 10,\n",
    "        'average': 25,\n",
    "        'good': 40,\n",
    "        'excellent': 50\n",
    "    }.get(interaction_quality, 25)\n",
    "    \n",
    "    feedback_bonus = {\n",
    "        'negative': 0,\n",
    "        'neutral': 10,\n",
    "        'positive': 25,\n",
    "        'exceptional': 50\n",
    "    }.get(user_feedback, 10)\n",
    "    \n",
    "    total_xp = (base_xp + feedback_bonus) * streak_multiplier\n",
    "    return math.floor(total_xp)\n",
    "\n# Example progression\n,
    "for level in [1, 5, 10, 25, 50, 75, 100]:\n",
    "    xp_required = calculate_xp_for_level(level)\n",
    "    print(f\"Level {level}: {xp_required:,} XP required\")\n",
    "\n# Example interaction XP\n,
    "print(\"\\nInteraction XP Examples:\")\n",
    "print(f\"Good interaction + positive feedback: {calculate_interaction_xp('good', 'positive')} XP\")\n",
    "print(f\"Excellent interaction + exceptional feedback (2x streak): {calculate_interaction_xp('excellent', 'exceptional', 2)} XP\")"
   ]
  },
