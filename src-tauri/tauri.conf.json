{
  "build": {
    "beforeDevCommand": "bun run dev:all",
    "beforeBuildCommand": "bun run build:frontend && bun run build:sidecar",
    "devPath": "http://localhost:3000",
    "distDir": "../out"
  },
  "package": {
    "productName": "Alchm",
    "version": "1.0.0"
  },
  "plugins": {
    "deep-link": {
      "schemes": ["alchm"]
    }
  },
  "tauri": {
    "bundle": {
      "identifier": "com.cookingwithcastro.alchm",
      "externalBin": ["bin/orchestrator", "bin/llama-cli"]
    },
    "security": {
      "csp": null,
      "assetProtocol": {
        "scope": ["$APPDATA/com.cookingwithcastro.alchm/models/**"]
      }
    },
    "allowlist": {
      "fs": {
        "all": false,
        "readFile": true,
        "readDir": true,
        "scope": ["$APPDATA/com.cookingwithcastro.alchm/models/**"]
      },
      "dialog": {
        "all": false,
        "open": false
      }
    }
  }
}
