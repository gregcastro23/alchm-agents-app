{
  "$schema": "https://raw.githubusercontent.com/nicedrop/tauri-docs/v2-dev/src/assets/tauri-conf-v2.schema.json",
  "productName": "Alchm",
  "version": "1.0.0",
  "identifier": "com.cookingwithcastro.alchm",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build && bun run build:sidecar",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "Alchm Desktop",
        "width": 1200,
        "height": 800,
        "url": "/desktop"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["bin/orchestrator", "bin/llama-server"]
  },
  "plugins": {
    "deep-link": {
      "schemes": ["alchm"]
    }
  }
}
