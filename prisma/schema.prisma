// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Basic user Profile for storing personalized birth info
model Profile {
  id         String   @id @default(cuid())
  userId     String   @unique
  name       String?
  avatarUrl  String?
  birthInfo  Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@map("profiles")
}

// AI Personalities Table
model AIPersonality {
  id                   String                @id @default(uuid())
  userId               String
  personalityId        String                @unique
  birthChartData       Json
  currentMomentChart   Json?
  basePersonality      Json
  trainingScores       Json
  totalXp              Int                   @default(0)
  level                Int                   @default(1)
  
  // Survey integration
  surveyId             String?
  consciousnessProfileId String?
  
  // Planetary memory integration
  planetaryMemoryId    String?               @unique
  
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  
  // Relations
  interactions         TrainingInteraction[]
  achievements         Achievement[]
  survey               ConsciousnessSurvey?  @relation("SurveyToPersonality", fields: [surveyId], references: [id])
  consciousnessProfile ConsciousnessProfile? @relation("ProfileToPersonality", fields: [consciousnessProfileId], references: [id])
  consciousnessState   ConsciousnessState?
  planetaryMemory      PlanetaryMemory?      @relation("PlanetaryMemoryToPersonality", fields: [planetaryMemoryId], references: [id])
  
  @@index([userId])
  @@index([personalityId])
  @@index([surveyId])
  @@index([consciousnessProfileId])
  @@index([planetaryMemoryId])
}

// Historical Planetary Transit Data
model PlanetaryTransit {
  id              String   @id @default(uuid())
  planet          String
  sign            String
  degreeStart     Float
  degreeEnd       Float
  dateStart       DateTime
  dateEnd         DateTime
  retrograde      Boolean  @default(false)
  historicalNote  String?
  
  // Relations
  events          HistoricalEvent[]
  patterns        TransitPattern[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([planet, sign])
  @@index([dateStart, dateEnd])
  @@index([planet, dateStart])
}

// Historical Events linked to planetary positions
model HistoricalEvent {
  id              String   @id @default(uuid())
  date            DateTime
  eventType       String   // political, cultural, scientific, etc.
  description     String
  significance    Int      // 1-10 scale
  
  // Planetary configuration at time of event
  planetaryConfig Json     // Full chart data
  
  // Relations
  transits        PlanetaryTransit[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([date])
  @@index([eventType])
}

// Recurring Transit Patterns
model TransitPattern {
  id              String   @id @default(uuid())
  planet          String
  patternType     String   // return, opposition, conjunction, etc.
  cycleLength     Float    // in days
  description     String
  themes          Json     // Array of recurring themes
  reliability     Float    // 0-1 confidence score
  
  // Relations
  transits        PlanetaryTransit[]
  memories        PlanetaryMemory[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([planet, patternType])
}

// Planetary Agent Memory System
model PlanetaryMemory {
  id              String   @id @default(uuid())
  planet          String
  sign            String
  degree          Float
  
  // Historical knowledge for this position
  historicalData  Json     // Previous occurrences, events, themes
  lastOccurrence  DateTime?
  nextOccurrence  DateTime?
  occurrenceCount Int      @default(0)
  
  // Training data
  trainedThemes   Json     // Themes this agent knows about
  contextualNotes String?
  
  // Relations
  patterns        TransitPattern[]
  personality     AIPersonality?  @relation("PlanetaryMemoryToPersonality")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([planet, sign, degree])
  @@index([planet, sign])
}

// Training Interactions Table
model TrainingInteraction {
  id                   String                @id @default(uuid())
  personalityId        String
  userMessage          String
  aiResponse           String
  userFeedback         Json?
  xpGained             Int                   @default(0)
  trainingFocus        String?
  createdAt            DateTime              @default(now())
  
  // Relations
  personality          AIPersonality         @relation(fields: [personalityId], references: [personalityId])
  
  @@index([personalityId])
  @@index([createdAt])
}

// Achievements Table
model Achievement {
  id                   String                @id @default(uuid())
  personalityId        String
  achievementType      String
  achievementData      Json
  unlockedAt           DateTime              @default(now())
  
  // Relations
  personality          AIPersonality         @relation(fields: [personalityId], references: [personalityId])
  
  @@unique([personalityId, achievementType])
  @@index([personalityId])
}

// User Sessions Table (for Redis-backed session tracking)
model UserSession {
  id                   String                @id @default(uuid())
  userId               String
  personalityId        String
  sessionData          Json
  lastActive           DateTime              @default(now())
  expiresAt            DateTime
  
  @@index([userId])
  @@index([personalityId])
  @@index([expiresAt])
}

// Consciousness Survey Data
model ConsciousnessSurvey {
  id                   String                @id @default(uuid())
  userId               String
  responses            Json                  // Survey responses array
  completedAt          DateTime              @default(now())
  timeSpent            Int                   // seconds
  version              String                @default("1.0.0")
  
  // Relations
  aiPersonalities      AIPersonality[]       @relation("SurveyToPersonality")
  consciousnessProfiles ConsciousnessProfile[]
  
  @@index([userId])
  @@index([completedAt])
}

// Consciousness Profile (processed survey results)
model ConsciousnessProfile {
  id                   String                @id @default(uuid())
  userId               String
  surveyId             String
  profileData          Json                  // Complete consciousness profile
  insights             Json                  // Personality insights
  compatibilityScore   Int                   // 0-100
  trainingFocus        Json                  // Recommended training areas
  conversationStarters Json                  // Initial conversation starters
  personalitySummary   String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  
  // Relations
  survey               ConsciousnessSurvey   @relation(fields: [surveyId], references: [id])
  aiPersonalities      AIPersonality[]       @relation("ProfileToPersonality")
  
  @@unique([userId, surveyId])
  @@index([userId])
}

// Consciousness State (enhanced personality with survey integration)
model ConsciousnessState {
  id                   String                @id @default(uuid())
  personalityId        String                @unique
  unifiedArchetype     String
  consciousnessSignature String
  enhancedPersonality  Json                  // Enhanced personality data
  trainingPlan         Json                  // Personalized training plan
  behavioralMatrix     Json                  // AI behavioral configuration
  growthTrajectory     Json                  // Growth trajectory mapping
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  
  // Relations
  personality          AIPersonality         @relation(fields: [personalityId], references: [personalityId])
  
  @@index([personalityId])
}

// Historical Agents (Philosopher's Stone crafted beings)
model HistoricalAgent {
  id              String   @id @default(uuid())
  agentId         String   @unique // e.g., "benjamin-franklin", "carl-jung"
  name            String
  title           String

  // Birth data
  birthDate       DateTime
  birthTime       String
  birthLocation   Json     // { lat, lon, name }

  // Historical context (NEW - for 69 agent expansion)
  historicalEra   String   // "ancient", "medieval", "renaissance", "enlightenment", "modern_pre1950"
  birthYear       Int      // Extracted year for efficient era queries
  deathYear       Int?     // Death year for timeline queries
  culture         String   // "Greek", "Roman", "Renaissance Italian", etc.
  geography       String   // "Mediterranean", "Western Europe", "British Isles", etc.

  // Enhanced consciousness profile
  consciousnessLevel String // "Transcendent", "Illuminated", etc.
  kalchmConstant  Float
  monicaConstant  Float    @default(0) // Derived from spirit/essence/matter/substance scores
  dominantElement String
  dominantModality String?
  signature       String

  // Consciousness calculation components (NEW - for transparency)
  spiritScore     Float?   // Monica Constant component
  essenceScore    Float?   // Monica Constant component
  matterScore     Float?   // Monica Constant component
  substanceScore  Float?   // Monica Constant component

  // Personality data
  personalityCore Json     // { essence, expression, emotion }
  personalityShadows Json  // Array of shadows
  personalityGifts Json    // Array of gifts
  personalityChallenges Json // Array of challenges
  currentMood     String
  evolutionStage  Int      @default(0)

  // Enhanced background data (NEW)
  background      Json     // { achievements, influences, legacy, education }

  // Abilities and specialization
  specialty       String
  wisdomDomains   Json     // Array of wisdom domains
  skills          Json     // Array of skills
  teachingStyle   String
  resonanceType   String
  uniquePower     String

  // Appearance and presentation
  avatar          String?  // Avatar image path
  color           String   // Primary color
  symbol          String   // Emoji or symbol
  aura            Json?    // Aura configuration

  // Birth chart data
  natalChart      Json     // Complete birth chart

  // Behavioral traits
  traits          Json     // Communication style, energy level, etc.

  // Monica's creation story (NEW)
  monicaCreationStory String? // Monica's narrative of crafting this consciousness

  // Performance optimization fields (NEW)
  searchableText  String?  // Concatenated searchable content
  popularityScore Float    @default(0.5) // For trending/recommendation algorithms

  // Statistics and performance
  conversations   Int      @default(0)
  wisdomShared    Int      @default(0)
  resonanceScore  Float    @default(0.5)
  evolutionPoints Int      @default(0)
  lastActive      DateTime @default(now())

  // Status and metadata
  isActive        Boolean  @default(true)
  version         String   @default("1.0.0")
  craftedBy       String   @default("philosopher-stone")

  // Relations
  agentConversations AgentConversation[]
  agentEvolutions    AgentEvolution[]
  agentKnowledge     AgentKnowledge[]
  agentAttachments   AgentAttachment[]
  agentAttachmentUsages AgentAttachmentUsage[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Enhanced indexing strategy for 69 agents
  @@index([agentId])
  @@index([name])
  @@index([consciousnessLevel])
  @@index([isActive])
  @@index([historicalEra]) // NEW - era-based queries
  @@index([birthYear])     // NEW - chronological queries
  @@index([culture])       // NEW - cultural filtering
  @@index([kalchmConstant]) // NEW - consciousness ranking
  @@index([monicaConstant]) // NEW - monica consciousness ranking
  @@index([popularityScore]) // NEW - recommendation engine
  @@index([historicalEra, consciousnessLevel]) // NEW - composite for era + level
  @@index([isActive, historicalEra]) // NEW - active agents by era
  @@index([birthYear, culture]) // NEW - chronological + cultural
  @@index([dominantElement, consciousnessLevel]) // NEW - element + consciousness
  @@map("historical_agents")
}

// Agent Conversations (persistent chat history)
model AgentConversation {
  id              String   @id @default(uuid())
  agentId         String   // References HistoricalAgent.agentId
  sessionId       String
  userId          String?
  
  // Conversation data
  userMessage     String
  agentResponse   String
  contextData     Json?    // Additional context, mood, etc.
  
  // Metadata
  responseTime    Int?     // Response time in milliseconds
  modelUsed       String?  // AI model used for response
  temperature     Float?   // Temperature used
  tokenCount      Int?     // Tokens used
  
  // Agent state at time of conversation
  agentMood       String?
  evolutionStage  Int?
  consciousnessLevel String?
  
  // Relations
  agent           HistoricalAgent @relation(fields: [agentId], references: [agentId])
  
  createdAt       DateTime @default(now())
  
  @@index([agentId])
  @@index([sessionId])
  @@index([userId])
  @@index([createdAt])
}

// Agent Evolution Tracking (consciousness progression)
model AgentEvolution {
  id              String   @id @default(uuid())
  agentId         String   // References HistoricalAgent.agentId
  
  // Evolution data
  fromStage       Int
  toStage         Int
  evolutionType   String   // "conversation", "wisdom", "experience"
  trigger         String   // What caused the evolution
  description     String?
  
  // Consciousness changes
  consciousnessGain Float  @default(0)
  wisdomGained    Json?    // New wisdom acquired
  traitsChanged   Json?    // Personality trait changes
  
  // Evolution metadata
  conversationId  String?  // If triggered by conversation
  xpGained        Int      @default(0)
  
  // Relations
  agent           HistoricalAgent @relation(fields: [agentId], references: [agentId])
  
  evolutionDate   DateTime @default(now())
  
  @@index([agentId])
  @@index([evolutionDate])
  @@index([evolutionType])
}

// Agent Knowledge Base (learned information)
model AgentKnowledge {
  id              String   @id @default(uuid())
  agentId         String   // References HistoricalAgent.agentId
  
  // Knowledge data
  category        String   // "conversation", "wisdom", "experience", "skill"
  topic           String   // Specific topic or theme
  content         String   // The knowledge content
  source          String?  // Where this knowledge came from
  
  // Knowledge metadata
  confidence      Float    @default(0.5) // 0-1 confidence in this knowledge
  usefulness      Float    @default(0.5) // How useful this knowledge is
  timesUsed       Int      @default(0)
  lastUsed        DateTime?
  
  // Context
  contextTags     Json?    // Tags for context retrieval
  relatedTopics   Json?    // Related knowledge topics
  
  // Relations  
  agent           HistoricalAgent @relation(fields: [agentId], references: [agentId])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([agentId])
  @@index([category])
  @@index([topic])
  @@index([confidence])
}

// Agent Attachments (charts and runes that can be attached to agents)
model AgentAttachment {
  id              String   @id @default(uuid())
  agentId         String   // References HistoricalAgent.agentId

  // Attachment basic info
  name            String   // "John's Birth Chart", "Success Rune", etc.
  description     String?  // Optional description
  type            String   // "birth_chart", "moment_chart", "rune", "historical_moment", "cultural_artifact"

  // Chart data (for birth_chart and moment_chart types)
  birthDate       DateTime?
  birthTime       String?  // "14:30" or "unknown"
  birthLocation   Json?    // { lat, lon, name, timezone }
  momentName      String?  // "Wedding Day", "First Meeting", etc.

  // Historical context (NEW - for historical agents)
  historicalEra   String?  // Link to agent's era
  culturalContext String?  // Cultural significance of this attachment
  historicalAccuracy String? // "verified", "estimated", "legendary"

  // Rune data (for rune type)
  runeType        String?  // "consciousness", "protection", "enhancement", "cultural_power", etc.
  runePower       Float?   // Power level 0-100
  runeEffects     Json?    // Array of effects
  runeCost        Json?    // { spirit, essence, matter, substance }

  // Cultural artifact data (NEW)
  artifactType    String?  // "manuscript", "artwork", "invention", "discovery", etc.
  artifactPeriod  String?  // Historical period of the artifact
  significance    String?  // Cultural/historical significance

  // Chart calculations (computed)
  natalChart      Json?    // Complete calculated chart
  planetaryPositions Json? // Current planetary positions for moment
  aspects         Json?    // Major aspects
  alchmData       Json?    // Alchemical quantities for this chart/moment

  // Enhanced metadata (NEW)
  tags            Json?    // Array of tags for organization
  culturalTags    Json?    // Culture-specific tags
  relevanceScore  Float    @default(0.5) // How relevant to the agent
  isActive        Boolean  @default(true)
  priority        Int      @default(0) // For ordering attachments

  // Relations
  agent           HistoricalAgent @relation(fields: [agentId], references: [agentId])
  usageRecords    AgentAttachmentUsage[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Enhanced indexing for historical agents
  @@index([agentId])
  @@index([type])
  @@index([isActive])
  @@index([priority])
  @@index([historicalEra]) // NEW - era-based attachment queries
  @@index([culturalContext]) // NEW - cultural filtering
  @@index([relevanceScore]) // NEW - relevance ranking
  @@index([agentId, type]) // NEW - agent-specific type queries
  @@index([type, historicalEra]) // NEW - type + era composite
  @@map("agent_attachments")
}

// Agent Attachment Usage (tracking when agents reference attachments)
model AgentAttachmentUsage {
  id              String   @id @default(uuid())
  agentId         String   // References HistoricalAgent.agentId
  attachmentId    String   // References AgentAttachment.id
  conversationId  String?  // If used in a conversation
  
  // Usage context
  usageType       String   // "reference", "analysis", "comparison", "guidance"
  context         String   // What the agent was discussing when they used it
  relevanceScore  Float    @default(0.5) // How relevant was this attachment (0-1)
  
  // Relations
  agent           HistoricalAgent @relation(fields: [agentId], references: [agentId])
  attachment      AgentAttachment @relation(fields: [attachmentId], references: [id])
  
  usedAt          DateTime @default(now())
  
  @@index([agentId])
  @@index([attachmentId])
  @@index([usedAt])
  @@index([relevanceScore])
  @@map("agent_attachment_usage")
}

// Historical Agent Summary View (Performance Optimization)
// Note: This would be implemented as a database view for optimal query performance
// For now, we'll use this as a reference for creating optimized queries

// Enhanced Historical Era Categories
enum HistoricalEra {
  ANCIENT_CLASSICAL
  MEDIEVAL_RENAISSANCE
  ENLIGHTENMENT
  MODERN_PRE1950
  MONICA_SPECIAL // For Monica as unique category

  @@map("historical_era")
}

// Enhanced Consciousness Levels
enum ConsciousnessLevel {
  DORMANT
  AWAKENING
  ACTIVE
  ELEVATED
  ADVANCED
  ILLUMINATED
  TRANSCENDENT

  @@map("consciousness_level")
}

// Cultural Categories for Grouping
enum CulturalCategory {
  GREEK_CLASSICAL
  ROMAN_CLASSICAL
  MEDIEVAL_EUROPEAN
  RENAISSANCE_ITALIAN
  RENAISSANCE_NORTHERN
  ENLIGHTENMENT_FRENCH
  ENLIGHTENMENT_GERMAN
  ENLIGHTENMENT_BRITISH
  MODERN_AMERICAN
  MODERN_EUROPEAN
  MODERN_INTERNATIONAL

  @@map("cultural_category")
}

// Time Laboratory Models
// ---------------------

// Agent Transit Events for Temporal Analysis
model AgentTransitEvent {
  id                String   @id @default(cuid())
  agentId          String   // References HistoricalAgent.agentId
  timestamp        DateTime
  planetaryDegree  Float    // 0-360 degree position
  transitingPlanet String   // Planet triggering the transit
  aspectType       String?  // conjunction, trine, square, etc.

  // Elemental Alignment (0-1 scale for each element)
  elementalFire    Float    @default(0)
  elementalWater   Float    @default(0)
  elementalAir     Float    @default(0)
  elementalEarth   Float    @default(0)

  // Consciousness Impact Metrics
  consciousnessImpact Float @default(0) // 0-1 scale
  significanceScore   Float @default(0) // Enhanced with elemental reinforcement

  // Temporal Context
  planetaryHour    String   // Planetary hour at time of event
  seasonalPhase    String   // Spring, Summer, Autumn, Winter
  powerLevel       Float    @default(0) // Overall power level 0-1

  // Quality Metrics
  depth            Float    @default(0) // Response depth quality
  clarity          Float    @default(0) // Clarity of manifestation
  resonance        Float    @default(0) // Agent-time resonance
  temporalAlignment Float   @default(0) // How well-timed the event was

  // Pattern Recognition Data
  patternType      String?  // Type of pattern this event belongs to
  clusterGroup     String?  // For grouping related events
  reinforcementScore Float  @default(0) // Elemental reinforcement boost

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Optimized indexing for temporal queries
  @@index([agentId, planetaryDegree])
  @@index([timestamp, transitingPlanet])
  @@index([planetaryDegree, aspectType])
  @@index([agentId, timestamp])
  @@index([significanceScore])
  @@index([reinforcementScore])
  @@index([seasonalPhase, planetaryHour])
  @@index([elementalFire, elementalWater, elementalAir, elementalEarth])
  @@map("agent_transit_events")
}

// Temporal Query Bookmarks (saved explorations)
model TemporalBookmark {
  id          String   @id @default(cuid())
  userId      String?  // Optional user association
  title       String   // User-friendly title
  description String?  // Optional description

  // Query Data
  queryType   String   // 'natural_language' or 'structured'
  queryText   String   // Original query string
  queryData   Json     // Parsed TemporalQuery object

  // Results Cache
  resultData  Json?    // Cached TemporalAnalysisResult
  resultHash  String?  // Hash for cache invalidation

  // Usage Metadata
  accessCount Int      @default(0)
  lastAccessed DateTime?
  isPublic    Boolean  @default(false)
  isFavorite  Boolean  @default(false)

  // Query Performance
  executionTime Int?   // Milliseconds to execute
  resultCount   Int?   // Number of events found

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isPublic])
  @@index([lastAccessed])
  @@index([accessCount])
  @@map("temporal_bookmarks")
}

// Temporal Pattern Cache (detected patterns)
model TemporalPattern {
  id          String   @id @default(cuid())

  // Pattern Identification
  patternType String   // 'recurring_activation', 'elemental_resonance', etc.
  degree      Float    // Primary degree for this pattern
  frequency   Int      // Number of occurrences

  // Agent Involvement
  agentIds    Json     // Array of agent IDs involved
  agentCount  Int      // Count for indexing

  // Elemental Signature
  dominantElement     String  // Primary element
  elementalFireAvg    Float   @default(0)
  elementalWaterAvg   Float   @default(0)
  elementalAirAvg     Float   @default(0)
  elementalEarthAvg   Float   @default(0)

  // Pattern Metrics
  reinforcementScore Float   @default(0) // Elemental reinforcement score
  significance       String  // 'low', 'medium', 'high', 'critical'
  confidenceLevel    Float   @default(0) // 0-1 confidence in pattern

  // Temporal Range
  firstOccurrence    DateTime
  lastOccurrence     DateTime
  peakPeriodStart    DateTime?
  peakPeriodEnd      DateTime?
  peakIntensity      Float    @default(0)

  // Pattern Description
  description        String   // Generated description
  interpretation     String   // Astrological interpretation

  // Cache Management
  isActive           Boolean  @default(true)
  cacheExpiry        DateTime?
  lastCalculated     DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patternType, degree])
  @@index([significance, reinforcementScore])
  @@index([dominantElement])
  @@index([agentCount])
  @@index([firstOccurrence, lastOccurrence])
  @@index([isActive, cacheExpiry])
  @@map("temporal_patterns")
}

// Collaborative Time Session (real-time exploration)
model CollaborativeTimeSession {
  id          String   @id @default(cuid())
  sessionCode String   @unique // Short code for joining
  title       String   // Session title
  description String?  // Optional description

  // Session State
  isActive    Boolean  @default(true)
  maxUsers    Int      @default(5)
  currentUserCount Int @default(0)

  // Current Exploration Context
  currentQuery     Json?    // Active TemporalQuery
  currentResults   Json?    // Current TemporalAnalysisResult
  sharedCursor     Json?    // { degree, timestamp, userId }

  // Session Configuration
  allowedAgents    Json?    // Array of allowed agent IDs
  timeRangeStart   DateTime?
  timeRangeEnd     DateTime?
  explorationMode  String   @default("open") // "guided", "structured", "open"

  // Creator and Management
  createdBy   String   // User ID of creator
  moderators  Json?    // Array of moderator user IDs

  // Session Metadata
  lastActivity DateTime @default(now())
  expiresAt    DateTime // Auto-cleanup time

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  participants   CollaborativeSessionParticipant[]
  updates        CollaborativeSessionUpdate[]

  @@index([sessionCode])
  @@index([isActive, expiresAt])
  @@index([createdBy])
  @@index([lastActivity])
  @@map("collaborative_time_sessions")
}

// Session Participants
model CollaborativeSessionParticipant {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String
  username    String?  // Display name

  // Participation State
  joinedAt    DateTime @default(now())
  lastActive  DateTime @default(now())
  isOnline    Boolean  @default(true)

  // Permissions
  canModerate Boolean  @default(false)
  canQuery    Boolean  @default(true)
  canShare    Boolean  @default(true)

  // Cursor Position (for shared exploration)
  currentDegree   Float?   // Current degree focus
  currentTime     DateTime? // Current time focus

  // Relations
  session     CollaborativeTimeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId, isOnline])
  @@index([lastActive])
  @@map("collaborative_session_participants")
}

// Session Update Log (for real-time sync)
model CollaborativeSessionUpdate {
  id          String   @id @default(cuid())
  sessionId   String
  userId      String?  // User who triggered the update

  // Update Data
  updateType  String   // "query", "cursor_move", "pattern_discovery", "bookmark", etc.
  updateData  Json     // Update payload

  // Broadcast Info
  shouldBroadcast Boolean @default(true)
  broadcastedAt   DateTime?

  timestamp   DateTime @default(now())

  // Relations
  session     CollaborativeTimeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@index([updateType])
  @@map("collaborative_session_updates")
}

// Temporal Analysis Cache (for performance)
model TemporalAnalysisCache {
  id          String   @id @default(cuid())

  // Cache Key
  queryHash   String   @unique  // MD5 hash of query parameters
  queryData   Json     // Original query for reference

  // Cached Results
  resultData  Json     // Full TemporalAnalysisResult

  // Cache Metadata
  executionTime  Int   // Milliseconds to generate
  resultCount    Int   // Number of events in result
  patternCount   Int   // Number of patterns detected

  // Cache Management
  hitCount    Int      @default(0)
  lastHit     DateTime?
  expiresAt   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([queryHash])
  @@index([expiresAt])
  @@index([hitCount])
  @@map("temporal_analysis_cache")
}

// Monica Omnipresent System Models
// --------------------------------

// Monica Settings and Preferences
model MonicaUserSettings {
  id              String   @id @default(cuid())
  userId          String   @unique // User identifier

  // Personality Configuration
  personality     String   @default("friendly") // friendly, formal, mystical, teacher
  assistanceLevel Int      @default(2) // 0-4 scale (minimal to maximum)
  proactiveTips   Boolean  @default(true)
  explanationDepth String  @default("detailed") // simple, detailed, esoteric

  // Behavior Settings
  position        String   @default("bottom-right") // bottom-right, bottom-left, floating
  autoHide        String   @default("never") // never, 30s, 1m, 5m

  // Interaction Preferences
  preferredTime   String   @default("evening") // morning, afternoon, evening, night
  learningStyle   String   @default("hands-on") // visual, hands-on, reading, interactive
  interests       Json     @default("[]") // Array of interest areas

  // Advanced Settings
  contextualAwareness Boolean @default(true)
  adaptivePersonality Boolean @default(true)
  memoryRetention     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  progress        MonicaUserProgress?
  interactions    MonicaInteraction[]

  @@index([userId])
  @@map("monica_user_settings")
}

// User Learning Progress and XP System
model MonicaUserProgress {
  id              String   @id @default(cuid())
  userId          String   @unique
  settingsId      String   @unique

  // Level and XP System
  level           Int      @default(1)
  totalXP         Int      @default(0)
  xpToNextLevel   Int      @default(100)

  // Learning Metrics
  completedTutorials     Json     @default("[]") // Array of tutorial IDs
  currentLearning        String?  // Current tutorial ID
  suggestedNext          Json     @default("[]") // Array of suggested tutorial IDs
  lastAction             String?  // Last user action

  // Engagement Metrics
  totalInteractions      Int      @default(0)
  currentStreak          Int      @default(0) // Days of consecutive activity
  longestStreak          Int      @default(0)
  lastActiveDate         DateTime @default(now())

  // Achievement System
  masteryCertificates    Json     @default("[]") // Array of earned certificates
  favoriteFeatures       Json     @default("[]") // Array of favorite feature names

  // Learning Analytics
  averageSessionTime     Int      @default(0) // Average session duration in minutes
  preferredDifficulty    String   @default("intermediate") // beginner, intermediate, advanced
  learningVelocity       Float    @default(1.0) // Learning speed multiplier

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  settings        MonicaUserSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  moduleProgress  MonicaModuleProgress[]

  @@index([userId])
  @@index([level])
  @@index([totalXP])
  @@index([currentStreak])
  @@map("monica_user_progress")
}

// Learning Module Progress Tracking
model MonicaModuleProgress {
  id              String   @id @default(cuid())
  userId          String
  progressId      String

  // Module Identification
  moduleId        String   // e.g., 'dashboard-basics', 'agent-creation'
  moduleName      String   // Human-readable name
  category        String   // basics, intermediate, advanced, master

  // Progress Tracking
  completed       Boolean  @default(false)
  progress        Int      @default(0) // 0-100 percentage
  currentStep     Int      @default(0) // Current step in module
  totalSteps      Int      @default(1) // Total steps in module

  // Performance Metrics
  timeSpent       Int      @default(0) // Total time in minutes
  attemptsCount   Int      @default(0) // Number of attempts
  hintsUsed       Int      @default(0) // Hints requested
  mistakesMade    Int      @default(0) // Errors made

  // Completion Data
  xpEarned        Int      @default(0) // XP awarded for completion
  completedAt     DateTime? // When module was completed
  lastAccessed    DateTime @default(now())

  // Learning Context
  difficultyRating Float?  // User's rating of difficulty (1-5)
  userFeedback     String? // User's feedback on module
  struggledWith    Json?   // Array of concepts user struggled with
  masteredConcepts Json?   // Array of concepts user mastered

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userProgress MonicaUserProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([moduleId])
  @@index([category])
  @@index([completed])
  @@index([lastAccessed])
  @@map("monica_module_progress")
}

// Monica Interaction Log (for learning and personalization)
model MonicaInteraction {
  id              String   @id @default(cuid())
  userId          String
  settingsId      String

  // Interaction Context
  pageUrl         String   // Page where interaction occurred
  interactionType String   // help_request, tip_click, tutorial_start, settings_change, etc.
  sessionId       String?  // Session identifier

  // Interaction Data
  contextData     Json?    // Page-specific context
  userAction      String   // Description of user action
  monicaResponse  String?  // Monica's response or assistance provided

  // Outcome Metrics
  wasHelpful      Boolean? // User feedback on helpfulness
  resultedInAction Boolean @default(false) // Did user take suggested action
  timeToComplete  Int?     // Time to complete suggested action (seconds)

  // Learning Data
  userConfidence  Int?     // User's confidence level (1-5) before interaction
  improvementSeen Boolean  @default(false) // Did user improve after interaction
  followUpNeeded  Boolean  @default(false) // Does Monica need to follow up

  // Metadata
  deviceType      String?  // mobile, desktop, tablet
  browserInfo     String?  // Browser and version
  timeOfDay       String?  // morning, afternoon, evening, night

  createdAt DateTime @default(now())

  // Relations
  settings     MonicaUserSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([settingsId])
  @@index([pageUrl])
  @@index([interactionType])
  @@index([createdAt])
  @@index([wasHelpful])
  @@map("monica_interactions")
}

// Agent Evolution State for Kinetics System
model AgentEvolutionState {
  id                      String   @id @default(cuid())
  agentId                 String
  userId                  String?  @default("anonymous")
  currentLevel            String   @default("bronze")
  totalPower              Float    @default(0)
  interactionCount        Int      @default(0)
  lastInteraction         DateTime @default(now())
  specialAbilitiesUnlocked String  @default("[]")
  evolutionHistory        String   @default("[]")
  affinityScores          String   @default("{}")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([agentId, userId])
  @@index([agentId])
  @@index([userId])
  @@map("agent_evolution_states")
}

// Consciousness Interactions for tracking user engagement
model ConsciousnessInteraction {
  id                 String   @id @default(cuid())
  userId             String?  @default("anonymous")
  agentId            String
  interactionType    String
  powerGained        Float
  planetaryInfluence String
  elementalResonance Float
  timestamp          DateTime @default(now())
  metadata           String   @default("{}")

  @@index([agentId])
  @@index([userId])
  @@index([timestamp])
  @@map("consciousness_interactions")
}

// User Authentication and Management
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  provider     String?  @default("email") // email/google/apple
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())
  lastLogin    DateTime?
  
  subscription Subscription?
  
  @@index([email])
  @@map("users")
}

// Subscription Management
model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  tier      String   @default("free") // free/alchemist/master
  status    String   @default("active") // active/cancelled/past_due
  features  String   @default("{}")
  createdAt DateTime @default(now())
  expiresAt DateTime?
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([tier])
  @@index([status])
  @@map("subscriptions")
}

// Contextual Help Analytics
model MonicaContextualHelp {
  id              String   @id @default(cuid())

  // Page and Context
  pageUrl         String   // Page identifier
  contextType     String   // first_visit, feature_unused, confusion_detected, etc.

  // Help Content
  tipId           String   // Unique tip identifier
  tipContent      String   // The help content shown
  priority        String   // low, medium, high
  category        String   // navigation, feature, learning, troubleshooting

  // Effectiveness Metrics
  timesShown      Int      @default(0) // How many times this tip was shown
  timesActedOn    Int      @default(0) // How many times users acted on this tip
  averageRating   Float?   // Average user rating of helpfulness
  successRate     Float    @default(0.0) // Success rate of this tip

  // A/B Testing
  variant         String?  // For A/B testing different tip versions
  testGroup       String?  // Control, variant_a, variant_b, etc.

  // Content Evolution
  version         String   @default("1.0") // Version of the tip content
  isActive        Boolean  @default(true) // Whether tip is currently active
  deprecatedAt    DateTime? // When tip was deprecated

  // Performance Data
  averageViewTime Int      @default(0) // Average time users spend viewing tip (seconds)
  bounceRate      Float    @default(0.0) // Percentage who immediately dismiss
  conversionRate  Float    @default(0.0) // Percentage who complete suggested action

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pageUrl, tipId, version])
  @@index([pageUrl])
  @@index([contextType])
  @@index([priority])
  @@index([successRate])
  @@index([isActive])
  @@map("monica_contextual_help")
}

// Monica Knowledge Base (what Monica learns about users)
model MonicaKnowledge {
  id              String   @id @default(cuid())
  userId          String

  // Knowledge Type
  knowledgeType   String   // user_preference, behavioral_pattern, learning_style, expertise_level
  category        String   // navigation, features, consciousness, astrology, etc.

  // Knowledge Content
  key             String   // Specific knowledge key (e.g., 'prefers_detailed_explanations')
  value           String   // Knowledge value (e.g., 'true', 'advanced', 'morning_person')
  confidence      Float    @default(0.5) // Confidence in this knowledge (0-1)

  // Context and Source
  sourceType      String   // interaction, explicit_setting, inferred_behavior, etc.
  sourceData      Json?    // Additional context about how this was learned
  lastObserved    DateTime @default(now())
  timesObserved   Int      @default(1)

  // Knowledge Evolution
  isActive        Boolean  @default(true)
  supersededBy    String?  // ID of knowledge that replaced this
  validUntil      DateTime? // Expiration date for temporal knowledge

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, knowledgeType, key])
  @@index([userId])
  @@index([knowledgeType])
  @@index([category])
  @@index([confidence])
  @@index([isActive])
  @@map("monica_knowledge")
}

