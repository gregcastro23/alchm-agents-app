# Planetary Agents Backend - .dockerignore
# Optimized for Express.js backend containerization

# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json

# Build outputs (keep dist for production builds)
coverage/
.nyc_output

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Logs
logs
*.log

# Environment files
.env
.env.local
.env.development
.env.test
.env.production

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Git
.git
.gitignore
.gitattributes

# Documentation
README.md
CHANGELOG.md
LICENSE
*.md

# Development tools
.prettierrc*
.eslintrc*
jest.config.js
tsconfig.json
nodemon.json

# Testing
test/
tests/
**/*.test.*
**/*.spec.*
__tests__/

# Temporary files
.tmp
tmp/
temp/

# Cache directories
.cache/

# TypeScript
*.tsbuildinfo

# Docker
Dockerfile*
docker-compose*
.dockerignore

# Scripts (allow health-check.js for Docker)
scripts/
!scripts/health-check.js

# Source maps in production
**/*.map