# =============================================================================
# PLANETARY AGENTS - PRODUCTION ENVIRONMENT CONFIGURATION (EXAMPLE)
# =============================================================================
# 🚀 Vercel Production Deployment Template
# Last Updated: 2025-10-14
#
# INSTRUCTIONS:
# 1. Copy this file to .env.production
# 2. Replace placeholder values with your actual credentials
# 3. Copy all variables to Vercel Dashboard → Settings → Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_BASE_URL=https://v0-planetary-agents.vercel.app

# -----------------------------------------------------------------------------
# AI API KEYS (REQUIRED ⚠️)
# -----------------------------------------------------------------------------
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# -----------------------------------------------------------------------------
# BACKEND API CONFIGURATION
# -----------------------------------------------------------------------------
# Update with your deployed backend URL (Render/Railway/Fly.io/etc)
NEXT_PUBLIC_BACKEND_URL=https://your-backend-url.onrender.com
NEXT_PUBLIC_WEBSOCKET_URL=wss://your-backend-url.onrender.com

# Backend Feature Flags
NEXT_PUBLIC_PLANETARY_HOURS_BACKEND=true
NEXT_PUBLIC_THERMODYNAMICS_BACKEND=true
NEXT_PUBLIC_TOKEN_CALCULATIONS_BACKEND=true
NEXT_PUBLIC_KINETICS_BACKEND=true

# -----------------------------------------------------------------------------
# AUTHENTICATION (NextAuth.js)
# -----------------------------------------------------------------------------
# Your production URL
NEXTAUTH_URL=https://v0-planetary-agents.vercel.app

# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
# Vercel Postgres: https://vercel.com/docs/storage/vercel-postgres
# Supabase: https://supabase.com/
# Neon: https://neon.tech/
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# -----------------------------------------------------------------------------
# CACHING (OPTIONAL - Recommended for Production)
# -----------------------------------------------------------------------------
# Upstash Redis: https://upstash.com/
# Redis Labs: https://redis.com/
# REDIS_URL=redis://your-redis-host:6379

# -----------------------------------------------------------------------------
# GALILEO OBSERVABILITY (OPTIONAL)
# -----------------------------------------------------------------------------
# Get from: https://www.galileo.ai/
GALILEO_API_KEY=your_galileo_api_key_here
GALILEO_PROJECT=AlchmPlanetaryAgents
GALILEO_LOG_STREAM=production
GALILEO_QUANTITIES_STREAM=alchm-quantities
GALILEO_FAIL_SILENTLY=true
GALILEO_LOG_ENABLED=false
GALILEO_VERBOSE_FALLBACK=true

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ADDITIVE_ONLY_ELEMENTS=true
ENABLE_TRANSIT_SCHEDULER=true
TRANSIT_SCHEDULER_INTERVAL=60
BACKGROUND_REFRESH_INTERVAL_MS=600000

# -----------------------------------------------------------------------------
# MONICA AI ASSISTANT
# -----------------------------------------------------------------------------
MONICA_DEFAULT_MODEL=gpt-4o-mini
NEXT_PUBLIC_MONICA_DEFAULT_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# CROSS-BACKEND SYNCHRONIZATION (OPTIONAL)
# -----------------------------------------------------------------------------
WHATTOEATNEXT_BASE_URL=https://api.whattoeatnext.com/api
WHATTOEATNEXT_API_KEY=your_api_key_here
CROSS_BACKEND_SYNC_ENABLED=true
SYNC_MONITORING_ENABLED=true
SYNC_HEALTH_CHECK_INTERVAL=300000
EMERGENCY_SYNC_PROTOCOL=enabled

# -----------------------------------------------------------------------------
# SECURITY & PERFORMANCE
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# Comma-separated list of allowed origins
CORS_ORIGINS=https://v0-planetary-agents.vercel.app,https://planetary-agents.vercel.app

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Request size limits
MAX_REQUEST_SIZE_MB=2

# Logging configuration
LOG_LEVEL=info
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# GEOGRAPHIC DEFAULTS
# -----------------------------------------------------------------------------
DEFAULT_LATITUDE=37.7749
DEFAULT_LONGITUDE=-122.4194

# -----------------------------------------------------------------------------
# OPTIONAL SERVICES
# -----------------------------------------------------------------------------
# SendGrid for email notifications
# Get from: https://sendgrid.com/
# SENDGRID_API_KEY=your_sendgrid_api_key
# FEEDBACK_FROM_EMAIL=noreply@v0-planetary-agents.vercel.app

# Sentry for error tracking
# Get from: https://sentry.io/
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# -----------------------------------------------------------------------------
# CLAUDE CODE (Development Tool - Not needed in production)
# -----------------------------------------------------------------------------
# CLAUDE_CODE_MAX_OUTPUT_TOKENS=65536

# =============================================================================
# VERCEL DEPLOYMENT CHECKLIST
# =============================================================================
#
# 1. CREATE .env.production FILE
#    - Copy this file to .env.production
#    - Replace all placeholder values with actual credentials
#
# 2. ADD ENVIRONMENT VARIABLES TO VERCEL
#    - Go to: https://vercel.com/dashboard
#    - Select project: planetary-agents
#    - Navigate to: Settings → Environment Variables
#    - Add each variable from .env.production
#    - Set scope: Production (and Preview/Development as needed)
#
# 3. REQUIRED VARIABLES (⚠️ Must be set)
#    ✅ ANTHROPIC_API_KEY
#    ✅ OPENAI_API_KEY
#    ✅ NEXTAUTH_URL
#    ✅ NEXTAUTH_SECRET
#    ✅ DATABASE_URL (if using database features)
#
# 4. RECOMMENDED VARIABLES
#    - NEXT_PUBLIC_BACKEND_URL (for Express backend)
#    - REDIS_URL (for caching)
#    - JWT_SECRET (for API auth)
#    - GALILEO_API_KEY (for observability)
#
# 5. OPTIONAL VARIABLES (Enhance functionality)
#    - SENDGRID_API_KEY (email notifications)
#    - SENTRY_DSN (error tracking)
#    - WHATTOEATNEXT_API_KEY (cross-backend sync)
#
# 6. ADD CUSTOM DOMAIN
#    - Go to: Settings → Domains
#    - Add: v0-planetary-agents.vercel.app
#    - Vercel will automatically configure it
#
# 7. CONFIGURE GIT INTEGRATION
#    - Go to: Settings → Git
#    - Production Branch: main
#    - Auto-deploy: Enabled
#    - Framework: Next.js
#
# 8. TRIGGER DEPLOYMENT
#    - Push to main branch, or
#    - Click "Redeploy" in Vercel Dashboard
#
# 9. VERIFY DEPLOYMENT
#    - Check build logs for errors
#    - Visit: https://v0-planetary-agents.vercel.app
#    - Test key features and API endpoints
#
# 10. MONITOR
#    - Watch Vercel Analytics
#    - Check Galileo logs (if enabled)
#    - Monitor Sentry errors (if enabled)
#
# =============================================================================
# SECURITY NOTES
# =============================================================================
#
# ⚠️  NEVER commit .env.production to git (it's in .gitignore)
# ⚠️  NEVER share API keys publicly
# ⚠️  Rotate secrets regularly (every 90 days recommended)
# ⚠️  Use different secrets for development/production
# ⚠️  Enable 2FA on all service accounts
# ⚠️  Use environment-specific API keys when possible
# ⚠️  Monitor API usage for unusual activity
#
# =============================================================================
