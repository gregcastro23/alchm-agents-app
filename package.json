{
  "name": "planetary-agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "typecheck:errors": "tsc --noEmit 2>&1 | grep -E 'error TS' | wc -l",
    "typecheck:summary": "tsc --noEmit 2>&1 | grep -E 'error TS' | head -20",
    "typecheck:by-file": "tsc --noEmit 2>&1 | grep -E 'error TS' | cut -d'(' -f1 | sort | uniq -c | sort -nr",
    "typecheck:missing-properties": "tsc --noEmit 2>&1 | grep -E \"Property '.*' does not exist\"",
    "typecheck:type-mismatches": "tsc --noEmit 2>&1 | grep -E 'is not assignable to type'",
    "lint:typescript": "eslint . --ext .ts,.tsx --rule '@typescript-eslint/no-explicit-any: warn'",
    "lint:errors-only": "eslint . --ext .js,.jsx,.ts,.tsx --quiet",
    "check": "yarn lint && yarn format:check && yarn typecheck",
    "linting-campaign:start": "echo '🚀 Starting TypeScript Error Resolution Campaign' && yarn typecheck:errors",
    "linting-campaign:summary": "echo '📊 Error Summary:' && yarn typecheck:summary",
    "linting-campaign:by-file": "echo '📁 Errors by File:' && yarn typecheck:by-file",
    "linting-campaign:missing-props": "echo '🔍 Missing Properties:' && yarn typecheck:missing-properties | head -10",
    "linting-campaign:type-mismatches": "echo '🔄 Type Mismatches:' && yarn typecheck:type-mismatches | head -10",
    "linting-campaign:progress": "echo '📈 Current Progress:' && echo 'Total errors:' $(yarn typecheck:errors 2>/dev/null) && echo 'Starting: 1065' && echo 'Resolved:' $((1065 - $(yarn typecheck:errors 2>/dev/null))) && echo 'Remaining:' $(yarn typecheck:errors 2>/dev/null)",
    "linting-campaign:report": "node scripts/linting-campaign.js report",
    "linting-campaign:patterns": "node scripts/linting-campaign.js patterns",
    "backend:install": "cd backend && yarn install",
    "backend:dev": "cd backend && ./scripts/start-dev.sh",
    "backend:build": "cd backend && yarn build",
    "backend:start": "cd backend && yarn start",
    "backend:test": "cd backend && yarn test",
    "backend:status": "curl -s http://localhost:8000/api/health | jq '.'",
    "full-stack:dev": "concurrently \"yarn dev\" \"yarn backend:dev\"",
    "full-stack:test": "yarn backend:test",
    "test:chat": "npx tsx test/chat-system/run-tests.ts",
    "test:chat:unit": "vitest run test/chat-system/unit/ --config vitest.unit.config.ts",
    "test:chat:integration": "vitest run test/chat-system/integration/",
    "test:chat:performance": "vitest run test/chat-system/performance/",
    "test:chat:watch": "vitest test/chat-system/unit/ test/chat-system/integration/",
    "test:chat:coverage": "vitest run --coverage test/chat-system/",
    "test:historical": "vitest run test/chat-system/unit/historical-council-chat.test.tsx",
    "test:planetary": "vitest run test/chat-system/unit/planetary-wisdom-chat.test.tsx",
    "test:laboratory": "vitest run test/chat-system/unit/consciousness-laboratory-chat.test.tsx",
    "test:api": "vitest run test/chat-system/integration/unified-api.test.ts",
    "test:benchmark": "vitest run test/chat-system/performance/benchmark.test.ts",
    "test:chat:report": "npx tsx -e \"console.log(JSON.stringify(require('./test-results/latest-summary.json'), null, 2))\"",
    "test:chat:clean": "rm -rf test-results coverage .vitest",
    "test:ci:chat": "yarn test:chat:clean && yarn test:chat && yarn test:chat:report",
    "dev:enhanced": "concurrently \"yarn dev\" \"yarn backend:dev\" \"yarn db:studio\"",
    "dev:debug": "NODE_OPTIONS='--inspect' yarn dev",
    "typecheck:watch": "tsc --noEmit --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "db:studio": "npx prisma studio",
    "prepare": "is-ci || husky install",
    "rag:setup": "./scripts/setup-rag.sh",
    "rag:ingest": "npx tsx lib/llamaindex/ingestion-pipeline.ts",
    "rag:test": "curl -X POST http://localhost:3000/api/agents/semantic-search -H 'Content-Type: application/json' -d '{\"concept\": \"wisdom\", \"topK\": 3}'",
    "rag:test:unit": "vitest run test/rag/",
    "rag:test:watch": "vitest test/rag/",
    "chroma:docker": "docker run -p 8000:8000 chromadb/chroma"
  },
