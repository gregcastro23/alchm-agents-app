{
  "framework": "nextjs",
  "buildCommand": "yarn build",
  "installCommand": "yarn install --frozen-lockfile",
  "build": {
    "env": {
      "NODE_VERSION": "20.18.1"
    }
  },
  "functions": {
    "app/api/**/*.ts": {
      "memory": 2048,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate"
        }
      ]
    }
  ]
}
