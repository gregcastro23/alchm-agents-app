# Render Environment Variables Template
# Copy these to your Render dashboard for each service

# =============================================================================
# FRONTEND SERVICE (planetary-agents-frontend)
# =============================================================================

# Node Configuration
NODE_ENV=production
NODE_VERSION=20.11.0

# Database (Get from Neon.tech or Supabase)
DATABASE_URL=postgresql://user:password@host.region.provider.com/database?sslmode=require

# Authentication
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET=YOUR_SECRET_HERE_USE_OPENSSL_RAND
NEXTAUTH_URL=https://your-frontend-name.onrender.com

# AI APIs
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...  # Optional

# Feature Flags
NEXT_PUBLIC_ADDITIVE_ONLY_ELEMENTS=true

# Backend Integration (Set after backend is deployed)
NEXT_PUBLIC_BACKEND_URL=https://your-backend-name.onrender.com
NEXT_PUBLIC_WEBSOCKET_URL=wss://your-backend-name.onrender.com

# Backend Feature Toggles (Start with false, enable after initial success)
NEXT_PUBLIC_PLANETARY_HOURS_BACKEND=false
NEXT_PUBLIC_THERMODYNAMICS_BACKEND=false
NEXT_PUBLIC_TOKEN_CALCULATIONS_BACKEND=false
NEXT_PUBLIC_KINETICS_BACKEND=false

# Observability (Optional - Recommended to disable or set fail-safe)
GALILEO_API_KEY=  # Leave empty or remove
GALILEO_FAIL_SILENTLY=true
GALILEO_LOG_ENABLED=false

# =============================================================================
# BACKEND SERVICE (planetary-agents-backend)
# =============================================================================

# Node Configuration
NODE_ENV=production
NODE_VERSION=20.11.0
PORT=8000
HOST=0.0.0.0

# Database (Same as frontend)
DATABASE_URL=postgresql://user:password@host.region.provider.com/database?sslmode=require

# CORS (Set to your frontend URL)
CORS_ORIGINS=https://your-frontend-name.onrender.com

# Feature Flags (Start disabled, enable after verification)
PLANETARY_HOURS_BACKEND=false
THERMODYNAMICS_BACKEND=false
TOKEN_CALCULATIONS_BACKEND=false
KINETICS_BACKEND=false

# WebSocket (Disabled for free tier)
ENABLE_WEBSOCKET=false

# Redis (Optional - Leave empty for memory fallback)
REDIS_URL=  # Optional: redis://...

# =============================================================================
# NOTES
# =============================================================================
#
# 1. DATABASE_URL:
#    - Use Neon.tech (free tier): https://neon.tech
#    - Use POOLED connection string for better performance
#    - Include ?sslmode=require at the end
#
# 2. NEXTAUTH_SECRET:
#    - Generate with: openssl rand -base64 32
#    - Must be at least 32 characters
#    - Keep secret and never commit to git
#
# 3. URLs:
#    - Replace "your-frontend-name" with actual Render service name
#    - Replace "your-backend-name" with actual Render service name
#    - No trailing slashes in URLs
#
# 4. OpenAI API Key:
#    - Get from: https://platform.openai.com/api-keys
#    - Ensure you have credits/billing set up
#    - Format: sk-proj-... (newer format) or sk-... (older format)
#
# 5. Deployment Order:
#    - Deploy backend first (so you know its URL)
#    - Then deploy frontend with NEXT_PUBLIC_BACKEND_URL set
#    - Or use render.yaml which links them automatically
#
# 6. After Initial Deployment:
#    - Verify health checks pass with all features disabled
#    - Gradually enable backend features one at a time
#    - Monitor performance and logs
#
# 7. Free Tier Limits:
#    - Services sleep after 15 min inactivity
#    - 512 MB RAM per service
#    - Shared CPU (slower builds)
#    - Consider upgrade if performance is critical
