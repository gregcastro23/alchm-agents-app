{
  "identifier": "default",
  "description": "Default capability for Alchm desktop app",
  "windows": ["main", "live-composer"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "shell:allow-open",
    "deep-link:default",
    "global-shortcut:default",
    "notification:default"
  ]
}
