# Planetary Agents - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ================================
# CRITICAL: Required for Deployment
# ================================

# NextAuth Configuration (REQUIRED)
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# Run: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Database (REQUIRED)
DATABASE_URL=postgresql://username:password@localhost:5432/planetary_agents
# Production: Use your hosted PostgreSQL URL (e.g., Neon, Supabase, PlanetScale)

# API Keys (REQUIRED)
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ================================
# AI Configuration
# ================================

# Claude Model Configuration
CLAUDE_DEFAULT_MODEL=claude-3-5-sonnet-20241022
CLAUDE_FAST_MODEL=claude-3-5-haiku-20241022
MONICA_DEFAULT_MODEL=claude-3-5-sonnet-20241022
MONICA_TEMPERATURE=0.7

# ================================
# Backend Services (REQUIRED for Astronomical Calculations)
# ================================

# Express Backend Gateway (port 8000)
# IMPORTANT: Required for Swiss Ephemeris astronomical calculations
# The backend performs all planetary position calculations using native Swiss Ephemeris
# For local development: http://localhost:8000
# For production: https://your-backend.onrender.com
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Backend Service Endpoints
NEXT_PUBLIC_KINETICS_BACKEND=${BACKEND_URL}/api/agent-kinetics
NEXT_PUBLIC_PLANETARY_HOURS_BACKEND=${BACKEND_URL}/api/planetary-hours
NEXT_PUBLIC_RUNE_AGENT_BACKEND=${BACKEND_URL}/api/rune-agent
NEXT_PUBLIC_THERMODYNAMICS_BACKEND=${BACKEND_URL}/api/thermodynamics
NEXT_PUBLIC_TOKEN_CALCULATIONS_BACKEND=${BACKEND_URL}/api/token-rates
NEXT_PUBLIC_TOKENS_BACKEND=${BACKEND_URL}/api/tokens

# Public Base URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ================================
# Caching & Performance (Optional)
# ================================

# Redis (Optional - enhances performance)
REDIS_URL=redis://localhost:6379
# If not provided, app will work without Redis caching

# Background Refresh Interval (milliseconds)
BACKGROUND_REFRESH_INTERVAL_MS=300000

# ================================
# Observability (Optional)
# ================================

# Galileo Observability Platform
GALILEO_API_KEY=your-galileo-api-key
GALILEO_BASE_URL=https://api.galileo.ai
GALILEO_PROJECT=planetary-agents
GALILEO_LOG_ENABLED=false
GALILEO_LOG_STREAM=main
GALILEO_QUANTITIES_STREAM=alchemical-quantities
GALILEO_FAIL_SILENTLY=true
GALILEO_VERBOSE_FALLBACK=false

# Sentry Error Tracking
SENTRY_DSN=your-sentry-dsn

# General Logging
LOG_LEVEL=info
LOGGING_ENDPOINT=https://your-logging-service.com

# ================================
# External APIs (Optional)
# ================================

# Astrological Data Service
ASTROLOGIZE_API_BASE=https://api.astrologize.com

# Email Service (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
FEEDBACK_FROM_EMAIL=feedback@planetary-agents.com

# Food Recommendations API
WHATTOEATNEXT_API_KEY=your-whattoeatnext-api-key
WHATTOEATNEXT_BASE_URL=https://api.whattoeatnext.com

# ================================
# AI Gateway (Optional)
# ================================

AI_GATEWAY_ENABLED=false
AI_GATEWAY_URL=https://your-ai-gateway.com
AI_GATEWAY_API_KEY=your-gateway-api-key

# ================================
# Feature Flags (Optional)
# ================================

# RAG (Retrieval-Augmented Generation) - PHASE 6 FEATURES
USE_RAG_GENERATION=true
USE_VECTOR_SEARCH=true
USE_RAG_CACHE=true

# Mock Generation (for testing without Anthropic API)
# Set to 'true' to test RAG pipeline with mock responses
# Set to 'false' when Anthropic API is available
USE_MOCK_GENERATION=true

# ChromaDB Vector Store Configuration
CHROMA_URL=http://localhost:8001
CHROMADB_URL=http://localhost:8001
CHROMADB_TENANT=default_tenant
CHROMADB_DATABASE=default_database
CHROMADB_AUTH_TOKEN=

# LlamaIndex Configuration
LLAMAINDEX_PERSIST_DIR=./data/llamaindex
LLAMAINDEX_CHUNK_SIZE=512
LLAMAINDEX_CHUNK_OVERLAP=50

# Embeddings Configuration (OpenAI)
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIMENSIONS=1536
EMBEDDINGS_BATCH_SIZE=100

# RAG Query Configuration
RAG_TOP_K=5
RAG_RELEVANCE_THRESHOLD=0.7
RAG_USE_RERANKING=true
RAG_MAX_CONTEXT_TOKENS=1500

# RAG Caching
RAG_CACHE_TTL=300
RAG_EMBEDDING_CACHE_TTL=3600

# Transit Scheduler
ENABLE_TRANSIT_SCHEDULER=false

# ================================
# Security (Optional)
# ================================

JWT_SECRET=your-jwt-secret-key

# ================================
# Development/Testing (Optional)
# ================================

NODE_ENV=development
DEBUG=false

# Prisma Configuration
PRISMA_CLIENT_ENGINE_TYPE=library
PRISMA_QUERY_ENGINE_LIBRARY=
PRISMA_CLIENT_DATA_PROXY_CLIENT_VERSION=
PRISMA_CLIENT_GET_TIME=
TEST_CLIENT_ENGINE_REMOTE_EXECUTOR=

# Dotenv Encryption
DOTENV_KEY=your-dotenv-key-if-using-encryption

# ================================
# Vercel Deployment Notes
# ================================

# For Vercel deployment, add these variables in:
# Project Settings → Environment Variables
#
# CRITICAL variables:
# - NEXTAUTH_SECRET (generate fresh for production)
# - DATABASE_URL (use production database)
# - ANTHROPIC_API_KEY
# - OPENAI_API_KEY
#
# OPTIONAL but recommended:
# - REDIS_URL (for better performance)
# - SENTRY_DSN (for error tracking)
# - GALILEO_API_KEY (for observability)
#
# Note: NEXTAUTH_URL is auto-detected on Vercel
