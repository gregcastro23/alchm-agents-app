{
  "$schema": "https://raw.githubusercontent.com/nicedrop/tauri-docs/v2-dev/src/assets/tauri-conf-v2.schema.json",
  "productName": "Alchm",
  "version": "1.0.0",
  "identifier": "com.cookingwithcastro.alchm",
  "build": {
    "beforeDevCommand": "bun run dev:desktop-shell",
    "beforeBuildCommand": "bun run build:desktop-shell && bun run build:sidecar",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../desktop-shell/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Alchm Desktop",
        "width": 1200,
        "height": 800,
        "url": "/"
      },
      {
        "label": "live-composer",
        "title": "Alchm Live Composer",
        "width": 600,
        "height": 120,
        "minWidth": 520,
        "minHeight": 112,
        "url": "/?surface=composer",
        "transparent": true,
        "decorations": false,
        "resizable": false,
        "center": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["bin/orchestrator", "bin/llama-server", "bin/alchm-mcp", "bin/pa-mcp"]
  },
  "plugins": {
    "deep-link": {
      "schemes": ["alchm"]
    }
  }
}
