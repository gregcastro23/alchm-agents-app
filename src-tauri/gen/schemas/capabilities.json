{
  "default": {
    "identifier": "default",
    "description": "Default capability for Alchm desktop app",
    "local": true,
    "windows": ["main", "ghost-feed", "live-composer"],
    "permissions": [
      "core:default",
      "shell:allow-execute",
      "shell:allow-spawn",
      "shell:allow-stdin-write",
      "shell:allow-kill",
      "shell:allow-open",
      "deep-link:default",
      "global-shortcut:default",
      "notification:default"
    ]
  }
}
