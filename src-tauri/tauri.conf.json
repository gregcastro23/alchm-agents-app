{
  "$schema": "https://raw.githubusercontent.com/nicedrop/tauri-docs/v2-dev/src/assets/tauri-conf-v2.schema.json",
  "productName": "Alchm",
  "version": "1.0.0",
  "identifier": "com.cookingwithcastro.alchm",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build && bun run build:sidecar",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Alchm Desktop",
        "width": 1200,
        "height": 800,
        "url": "/desktop"
      },
      {
        "label": "ghost-feed",
        "title": "Alchm Ghost Feed",
        "width": 420,
        "height": 900,
        "minWidth": 360,
        "minHeight": 640,
        "x": 24,
        "y": 72,
        "url": "/desktop/ghost-feed",
        "transparent": true,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "focus": false
      },
      {
        "label": "live-composer",
        "title": "Alchm Live Composer",
        "width": 600,
        "height": 120,
        "minWidth": 520,
        "minHeight": 112,
        "url": "/desktop/composer",
        "transparent": true,
        "decorations": false,
        "resizable": false,
        "center": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["bin/orchestrator", "bin/llama-server"]
  },
  "plugins": {
    "deep-link": {
      "schemes": ["alchm"]
    }
  }
}
