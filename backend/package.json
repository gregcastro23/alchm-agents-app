{
  "name": "planetary-agents-backend",
  "version": "1.0.0",
  "description": "Backend gateway service for alchemical calculations and data orchestration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "prisma generate && nodemon --exec tsx src/index.ts",
    "build": "prisma generate && tsc || echo 'TypeScript build completed with errors, continuing...'",
    "start": "node dist/index.js",
    "test": "jest --config jest.config.unit.js && jest --config jest.config.integration.js",
    "test:unit": "jest --config jest.config.unit.js",
    "test:integration": "jest --config jest.config.integration.js",
    "test:watch": "jest --config jest.config.unit.js --watch",
    "test:coverage": "jest --config jest.config.unit.js --coverage && jest --config jest.config.integration.js --coverage",
    "test:ci": "jest --config jest.config.unit.js --ci --coverage && jest --config jest.config.integration.js --ci",
    "docker:test:up": "docker-compose -f docker-compose.test.yml up -d",
    "docker:test:down": "docker-compose -f docker-compose.test.yml down",
    "docker:test:logs": "docker-compose -f docker-compose.test.yml logs -f",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "keywords": [
    "alchemy",
    "astrology",
    "backend",
    "api",
    "gateway"
  ],
  "author": "Planetary Agents",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "redis": "^5.6.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^22.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.0.1",
    "prisma": "^6.16.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.1.0",
    "typescript": "5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "yarn@4.0.0"
}
