# =====================================
# Simplified Production Dockerfile for Render
# =====================================
FROM node:18-alpine

# Install dependencies for native modules
RUN apk add --no-cache \
    libc6-compat \
    python3 \
    make \
    g++ \
    dumb-init \
    curl \
    ca-certificates \
    && update-ca-certificates

# Enable Corepack for Yarn support
RUN corepack enable

WORKDIR /app/backend

# Copy backend source and necessary root files when context is repo root
COPY backend/ .
COPY prisma ../prisma

# Ensure we use node-modules (not PnP)
RUN echo "nodeLinker: node-modules" > .yarnrc.yml

# Install dependencies and build
RUN yarn install --immutable && \
    yarn build && \
    yarn cache clean

# Create non-root user for security
RUN addgroup -g 1001 -S nodejs && \
    adduser -S backend -u 1001

# Create necessary directories with proper permissions
RUN mkdir -p logs temp && \
    chown -R backend:nodejs logs temp dist

# Switch to non-root user
USER backend

# Set production environment variables
ENV NODE_ENV=production
ENV NODE_OPTIONS="--max-old-space-size=512"

# Expose ports
EXPOSE 8000 8001

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=15s --retries=3 \
  CMD curl -f http://localhost:8000/api/health || exit 1

# Use dumb-init to handle signals properly
ENTRYPOINT ["dumb-init", "--"]

# Start the application
CMD ["node", "dist/index.js"]
