generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String?
  avatarUrl String?
  birthInfo Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("profiles")
}

model UserProfile {
  id                   String         @id @default(cuid())
  userId               String         @unique
  birthDate            DateTime
  birthTime            String?
  birthLocation        Json
  natalChart           Json
  monicaConstant       Float
  dominantElement      String
  allowPublicAgents    Boolean        @default(false)
  shareChartWithAgents Boolean        @default(true)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  createdAgents        CreatedAgent[]
  user                 User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_profiles")
}

model AIPersonality {
  id                     String                @id @default(uuid())
  userId                 String
  personalityId          String                @unique
  birthChartData         Json
  currentMomentChart     Json?
  basePersonality        Json
  trainingScores         Json
  totalXp                Int                   @default(0)
  level                  Int                   @default(1)
  surveyId               String?
  consciousnessProfileId String?
  planetaryMemoryId      String?               @unique
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  consciousnessProfile   ConsciousnessProfile? @relation("ProfileToPersonality", fields: [consciousnessProfileId], references: [id])
  planetaryMemory        PlanetaryMemory?      @relation("PlanetaryMemoryToPersonality", fields: [planetaryMemoryId], references: [id])
  survey                 ConsciousnessSurvey?  @relation("SurveyToPersonality", fields: [surveyId], references: [id])
  achievements           Achievement[]
  consciousnessState     ConsciousnessState?
  interactions           TrainingInteraction[]

  @@index([userId])
  @@index([personalityId])
  @@index([surveyId])
  @@index([consciousnessProfileId])
  @@index([planetaryMemoryId])
}

model PlanetaryTransit {
  id             String            @id @default(uuid())
  planet         String
  sign           String
  degreeStart    Float
  degreeEnd      Float
  dateStart      DateTime
  dateEnd        DateTime
  retrograde     Boolean           @default(false)
  historicalNote String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  events         HistoricalEvent[] @relation("HistoricalEventToPlanetaryTransit")
  patterns       TransitPattern[]  @relation("PlanetaryTransitToTransitPattern")

  @@index([planet, sign])
  @@index([dateStart, dateEnd])
  @@index([planet, dateStart])
}

model HistoricalEvent {
  id              String             @id @default(uuid())
  date            DateTime
  eventType       String
  description     String
  significance    Int
  planetaryConfig Json
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  transits        PlanetaryTransit[] @relation("HistoricalEventToPlanetaryTransit")

  @@index([date])
  @@index([eventType])
}

model TransitPattern {
  id          String             @id @default(uuid())
  planet      String
  patternType String
  cycleLength Float
  description String
  themes      Json
  reliability Float
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  memories    PlanetaryMemory[]  @relation("PlanetaryMemoryToTransitPattern")
  transits    PlanetaryTransit[] @relation("PlanetaryTransitToTransitPattern")

  @@index([planet, patternType])
}

model PlanetaryMemory {
  id              String           @id @default(uuid())
  planet          String
  sign            String
  degree          Float
  historicalData  Json
  lastOccurrence  DateTime?
  nextOccurrence  DateTime?
  occurrenceCount Int              @default(0)
  trainedThemes   Json
  contextualNotes String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  personality     AIPersonality?   @relation("PlanetaryMemoryToPersonality")
  patterns        TransitPattern[] @relation("PlanetaryMemoryToTransitPattern")

  @@unique([planet, sign, degree])
  @@index([planet, sign])
}

model TrainingInteraction {
  id            String        @id @default(uuid())
  personalityId String
  userMessage   String
  aiResponse    String
  userFeedback  Json?
  xpGained      Int           @default(0)
  trainingFocus String?
  createdAt     DateTime      @default(now())
  personality   AIPersonality @relation(fields: [personalityId], references: [personalityId])

  @@index([personalityId])
  @@index([createdAt])
}

model Achievement {
  id              String        @id @default(uuid())
  personalityId   String
  achievementType String
  achievementData Json
  unlockedAt      DateTime      @default(now())
  personality     AIPersonality @relation(fields: [personalityId], references: [personalityId])

  @@unique([personalityId, achievementType])
  @@index([personalityId])
}

model UserSession {
  id            String   @id @default(uuid())
  userId        String
  personalityId String
  sessionData   Json
  lastActive    DateTime @default(now())
  expiresAt     DateTime

  @@index([userId])
  @@index([personalityId])
  @@index([expiresAt])
}

model ConsciousnessSurvey {
  id                    String                 @id @default(uuid())
  userId                String
  responses             Json
  completedAt           DateTime               @default(now())
  timeSpent             Int
  version               String                 @default("1.0.0")
  aiPersonalities       AIPersonality[]        @relation("SurveyToPersonality")
  consciousnessProfiles ConsciousnessProfile[]

  @@index([userId])
  @@index([completedAt])
}

model ConsciousnessProfile {
  id                   String              @id @default(uuid())
  userId               String
  surveyId             String
  profileData          Json
  insights             Json
  compatibilityScore   Int
  trainingFocus        Json
  conversationStarters Json
  personalitySummary   String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  aiPersonalities      AIPersonality[]     @relation("ProfileToPersonality")
  survey               ConsciousnessSurvey @relation(fields: [surveyId], references: [id])

  @@unique([userId, surveyId])
  @@index([userId])
}

model ConsciousnessState {
  id                     String        @id @default(uuid())
  personalityId          String        @unique
  unifiedArchetype       String
  consciousnessSignature String
  enhancedPersonality    Json
  trainingPlan           Json
  behavioralMatrix       Json
  growthTrajectory       Json
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  personality            AIPersonality @relation(fields: [personalityId], references: [personalityId])

  @@index([personalityId])
}

model HistoricalAgent {
  id                    String                 @id @default(uuid())
  agentId               String                 @unique
  name                  String
  title                 String
  birthDate             DateTime
  birthTime             String
  birthLocation         Json
  historicalEra         String
  birthYear             Int
  deathYear             Int?
  culture               String
  geography             String
  consciousnessLevel    String
  kalchmConstant        Float
  monicaConstant        Float                  @default(0)
  dominantElement       String
  dominantModality      String?
  signature             String
  spiritScore           Float?
  essenceScore          Float?
  matterScore           Float?
  substanceScore        Float?
  personalityCore       Json
  personalityShadows    Json
  personalityGifts      Json
  personalityChallenges Json
  currentMood           String
  evolutionStage        Int                    @default(0)
  background            Json
  specialty             String
  wisdomDomains         Json
  skills                Json
  teachingStyle         String
  resonanceType         String
  uniquePower           String
  avatar                String?
  color                 String
  symbol                String
  aura                  Json?
  natalChart            Json
  traits                Json
  monicaCreationStory   String?
  searchableText        String?
  popularityScore       Float                  @default(0.5)
  conversations         Int                    @default(0)
  wisdomShared          Int                    @default(0)
  resonanceScore        Float                  @default(0.5)
  evolutionPoints       Int                    @default(0)
  lastActive            DateTime               @default(now())
  isActive              Boolean                @default(true)
  version               String                 @default("1.0.0")
  craftedBy             String                 @default("philosopher-stone")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  agentConversations    AgentConversation[]
  agentEvolutions       AgentEvolution[]
  agentKnowledge        AgentKnowledge[]
  agentAttachmentUsages AgentAttachmentUsage[]
  agentAttachments      AgentAttachment[]

  @@index([agentId])
  @@index([name])
  @@index([consciousnessLevel])
  @@index([isActive])
  @@index([historicalEra])
  @@index([birthYear])
  @@index([culture])
  @@index([kalchmConstant])
  @@index([monicaConstant])
  @@index([popularityScore])
  @@index([historicalEra, consciousnessLevel])
  @@index([isActive, historicalEra])
  @@index([birthYear, culture])
  @@index([dominantElement, consciousnessLevel])
  @@map("historical_agents")
}

model AgentConversation {
  id                 String          @id @default(uuid())
  agentId            String
  sessionId          String
  userId             String?
  userMessage        String
  agentResponse      String
  contextData        Json?
  responseTime       Int?
  modelUsed          String?
  temperature        Float?
  tokenCount         Int?
  agentMood          String?
  evolutionStage     Int?
  consciousnessLevel String?
  createdAt          DateTime        @default(now())
  agent              HistoricalAgent @relation(fields: [agentId], references: [agentId])

  @@index([agentId])
  @@index([sessionId])
  @@index([userId])
  @@index([createdAt])
}

model AgentEvolution {
  id                String          @id @default(uuid())
  agentId           String
  fromStage         Int
  toStage           Int
  evolutionType     String
  trigger           String
  description       String?
  consciousnessGain Float           @default(0)
  wisdomGained      Json?
  traitsChanged     Json?
  conversationId    String?
  xpGained          Int             @default(0)
  evolutionDate     DateTime        @default(now())
  agent             HistoricalAgent @relation(fields: [agentId], references: [agentId])

  @@index([agentId])
  @@index([evolutionDate])
  @@index([evolutionType])
}

model AgentKnowledge {
  id            String          @id @default(uuid())
  agentId       String
  category      String
  topic         String
  content       String
  source        String?
  confidence    Float           @default(0.5)
  usefulness    Float           @default(0.5)
  timesUsed     Int             @default(0)
  lastUsed      DateTime?
  contextTags   Json?
  relatedTopics Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  agent         HistoricalAgent @relation(fields: [agentId], references: [agentId])

  @@index([agentId])
  @@index([category])
  @@index([topic])
  @@index([confidence])
}

model AgentAttachment {
  id                 String                 @id @default(uuid())
  agentId            String
  name               String
  description        String?
  type               String
  birthDate          DateTime?
  birthTime          String?
  birthLocation      Json?
  momentName         String?
  historicalEra      String?
  culturalContext    String?
  historicalAccuracy String?
  runeType           String?
  runePower          Float?
  runeEffects        Json?
  runeCost           Json?
  artifactType       String?
  artifactPeriod     String?
  significance       String?
  natalChart         Json?
  planetaryPositions Json?
  aspects            Json?
  alchmData          Json?
  tags               Json?
  culturalTags       Json?
  relevanceScore     Float                  @default(0.5)
  isActive           Boolean                @default(true)
  priority           Int                    @default(0)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  usageRecords       AgentAttachmentUsage[]
  agent              HistoricalAgent        @relation(fields: [agentId], references: [agentId])

  @@index([agentId])
  @@index([type])
  @@index([isActive])
  @@index([priority])
  @@index([historicalEra])
  @@index([culturalContext])
  @@index([relevanceScore])
  @@index([agentId, type])
  @@index([type, historicalEra])
  @@map("agent_attachments")
}

model AgentAttachmentUsage {
  id             String          @id @default(uuid())
  agentId        String
  attachmentId   String
  conversationId String?
  usageType      String
  context        String
  relevanceScore Float           @default(0.5)
  usedAt         DateTime        @default(now())
  agent          HistoricalAgent @relation(fields: [agentId], references: [agentId])
  attachment     AgentAttachment @relation(fields: [attachmentId], references: [id])

  @@index([agentId])
  @@index([attachmentId])
  @@index([usedAt])
  @@index([relevanceScore])
  @@map("agent_attachment_usage")
}

model CreatedAgent {
  id               String       @id @default(cuid())
  creatorId        String?
  sourceType       String
  birthChart       Json?
  momentChart      Json
  additionalCharts Json?
  blueprint        Json
  monicaConstant   Float
  personality      Json
  isActive         Boolean      @default(true)
  lastUsed         DateTime?
  createdAt        DateTime     @default(now())
  userProfileId    String?
  creator          User?        @relation(fields: [creatorId], references: [id])
  userProfile      UserProfile? @relation(fields: [userProfileId], references: [id])

  @@index([creatorId])
  @@map("created_agents")
}

model AgentTransitEvent {
  id                  String   @id @default(cuid())
  agentId             String
  timestamp           DateTime
  planetaryDegree     Float
  transitingPlanet    String
  aspectType          String?
  elementalFire       Float    @default(0)
  elementalWater      Float    @default(0)
  elementalAir        Float    @default(0)
  elementalEarth      Float    @default(0)
  consciousnessImpact Float    @default(0)
  significanceScore   Float    @default(0)
  planetaryHour       String
  seasonalPhase       String
  powerLevel          Float    @default(0)
  depth               Float    @default(0)
  clarity             Float    @default(0)
  resonance           Float    @default(0)
  temporalAlignment   Float    @default(0)
  patternType         String?
  clusterGroup        String?
  reinforcementScore  Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([agentId, planetaryDegree])
  @@index([timestamp, transitingPlanet])
  @@index([planetaryDegree, aspectType])
  @@index([agentId, timestamp])
  @@index([significanceScore])
  @@index([reinforcementScore])
  @@index([seasonalPhase, planetaryHour])
  @@index([elementalFire, elementalWater, elementalAir, elementalEarth])
  @@map("agent_transit_events")
}

model TemporalBookmark {
  id            String    @id @default(cuid())
  userId        String?
  title         String
  description   String?
  queryType     String
  queryText     String
  queryData     Json
  resultData    Json?
  resultHash    String?
  accessCount   Int       @default(0)
  lastAccessed  DateTime?
  isPublic      Boolean   @default(false)
  isFavorite    Boolean   @default(false)
  executionTime Int?
  resultCount   Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([isPublic])
  @@index([lastAccessed])
  @@index([accessCount])
  @@map("temporal_bookmarks")
}

model TemporalPattern {
  id                 String    @id @default(cuid())
  patternType        String
  degree             Float
  frequency          Int
  agentIds           Json
  agentCount         Int
  dominantElement    String
  elementalFireAvg   Float     @default(0)
  elementalWaterAvg  Float     @default(0)
  elementalAirAvg    Float     @default(0)
  elementalEarthAvg  Float     @default(0)
  reinforcementScore Float     @default(0)
  significance       String
  confidenceLevel    Float     @default(0)
  firstOccurrence    DateTime
  lastOccurrence     DateTime
  peakPeriodStart    DateTime?
  peakPeriodEnd      DateTime?
  peakIntensity      Float     @default(0)
  description        String
  interpretation     String
  isActive           Boolean   @default(true)
  cacheExpiry        DateTime?
  lastCalculated     DateTime  @default(now())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([patternType, degree])
  @@index([significance, reinforcementScore])
  @@index([dominantElement])
  @@index([agentCount])
  @@index([firstOccurrence, lastOccurrence])
  @@index([isActive, cacheExpiry])
  @@map("temporal_patterns")
}

model CollaborativeTimeSession {
  id               String                            @id @default(cuid())
  sessionCode      String                            @unique
  title            String
  description      String?
  isActive         Boolean                           @default(true)
  maxUsers         Int                               @default(5)
  currentUserCount Int                               @default(0)
  currentQuery     Json?
  currentResults   Json?
  sharedCursor     Json?
  allowedAgents    Json?
  timeRangeStart   DateTime?
  timeRangeEnd     DateTime?
  explorationMode  String                            @default("open")
  createdBy        String
  moderators       Json?
  lastActivity     DateTime                          @default(now())
  expiresAt        DateTime
  createdAt        DateTime                          @default(now())
  updatedAt        DateTime                          @updatedAt
  participants     CollaborativeSessionParticipant[]
  updates          CollaborativeSessionUpdate[]

  @@index([sessionCode])
  @@index([isActive, expiresAt])
  @@index([createdBy])
  @@index([lastActivity])
  @@map("collaborative_time_sessions")
}

model CollaborativeSessionParticipant {
  id            String                   @id @default(cuid())
  sessionId     String
  userId        String
  username      String?
  joinedAt      DateTime                 @default(now())
  lastActive    DateTime                 @default(now())
  isOnline      Boolean                  @default(true)
  canModerate   Boolean                  @default(false)
  canQuery      Boolean                  @default(true)
  canShare      Boolean                  @default(true)
  currentDegree Float?
  currentTime   DateTime?
  session       CollaborativeTimeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([sessionId, isOnline])
  @@index([lastActive])
  @@map("collaborative_session_participants")
}

model CollaborativeSessionUpdate {
  id              String                   @id @default(cuid())
  sessionId       String
  userId          String?
  updateType      String
  updateData      Json
  shouldBroadcast Boolean                  @default(true)
  broadcastedAt   DateTime?
  timestamp       DateTime                 @default(now())
  session         CollaborativeTimeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@index([updateType])
  @@map("collaborative_session_updates")
}

model TemporalAnalysisCache {
  id            String    @id @default(cuid())
  queryHash     String    @unique
  queryData     Json
  resultData    Json
  executionTime Int
  resultCount   Int
  patternCount  Int
  hitCount      Int       @default(0)
  lastHit       DateTime?
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([queryHash])
  @@index([expiresAt])
  @@index([hitCount])
  @@map("temporal_analysis_cache")
}

model MonicaUserSettings {
  id                  String              @id @default(cuid())
  userId              String              @unique
  personality         String              @default("friendly")
  assistanceLevel     Int                 @default(2)
  proactiveTips       Boolean             @default(true)
  explanationDepth    String              @default("detailed")
  position            String              @default("bottom-right")
  autoHide            String              @default("never")
  preferredTime       String              @default("evening")
  learningStyle       String              @default("hands-on")
  interests           Json                @default("[]")
  contextualAwareness Boolean             @default(true)
  adaptivePersonality Boolean             @default(true)
  memoryRetention     Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  interactions        MonicaInteraction[]
  progress            MonicaUserProgress?

  @@index([userId])
  @@map("monica_user_settings")
}

model MonicaUserProgress {
  id                  String                 @id @default(cuid())
  userId              String                 @unique
  settingsId          String                 @unique
  level               Int                    @default(1)
  totalXP             Int                    @default(0)
  xpToNextLevel       Int                    @default(100)
  completedTutorials  Json                   @default("[]")
  currentLearning     String?
  suggestedNext       Json                   @default("[]")
  lastAction          String?
  totalInteractions   Int                    @default(0)
  currentStreak       Int                    @default(0)
  longestStreak       Int                    @default(0)
  lastActiveDate      DateTime               @default(now())
  masteryCertificates Json                   @default("[]")
  favoriteFeatures    Json                   @default("[]")
  averageSessionTime  Int                    @default(0)
  preferredDifficulty String                 @default("intermediate")
  learningVelocity    Float                  @default(1.0)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  moduleProgress      MonicaModuleProgress[]
  settings            MonicaUserSettings     @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([level])
  @@index([totalXP])
  @@index([currentStreak])
  @@map("monica_user_progress")
}

model MonicaModuleProgress {
  id               String             @id @default(cuid())
  userId           String
  progressId       String
  moduleId         String
  moduleName       String
  category         String
  completed        Boolean            @default(false)
  progress         Int                @default(0)
  currentStep      Int                @default(0)
  totalSteps       Int                @default(1)
  timeSpent        Int                @default(0)
  attemptsCount    Int                @default(0)
  hintsUsed        Int                @default(0)
  mistakesMade     Int                @default(0)
  xpEarned         Int                @default(0)
  completedAt      DateTime?
  lastAccessed     DateTime           @default(now())
  difficultyRating Float?
  userFeedback     String?
  struggledWith    Json?
  masteredConcepts Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  userProgress     MonicaUserProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([moduleId])
  @@index([category])
  @@index([completed])
  @@index([lastAccessed])
  @@map("monica_module_progress")
}

model MonicaInteraction {
  id               String             @id @default(cuid())
  userId           String
  settingsId       String
  pageUrl          String
  interactionType  String
  sessionId        String?
  contextData      Json?
  userAction       String
  monicaResponse   String?
  wasHelpful       Boolean?
  resultedInAction Boolean            @default(false)
  timeToComplete   Int?
  userConfidence   Int?
  improvementSeen  Boolean            @default(false)
  followUpNeeded   Boolean            @default(false)
  deviceType       String?
  browserInfo      String?
  timeOfDay        String?
  createdAt        DateTime           @default(now())
  settings         MonicaUserSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([settingsId])
  @@index([pageUrl])
  @@index([interactionType])
  @@index([createdAt])
  @@index([wasHelpful])
  @@map("monica_interactions")
}

model AgentEvolutionState {
  id                       String   @id @default(cuid())
  agentId                  String
  userId                   String?  @default("anonymous")
  currentLevel             String   @default("bronze")
  totalPower               Float    @default(0)
  interactionCount         Int      @default(0)
  lastInteraction          DateTime @default(now())
  specialAbilitiesUnlocked String   @default("[]")
  evolutionHistory         String   @default("[]")
  affinityScores           String   @default("{}")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([agentId, userId])
  @@index([agentId])
  @@index([userId])
  @@map("agent_evolution_states")
}

model ConsciousnessInteraction {
  id                 String   @id @default(cuid())
  userId             String?  @default("anonymous")
  agentId            String
  interactionType    String
  powerGained        Float
  planetaryInfluence String
  elementalResonance Float
  forceMagnitude     Float?
  timestamp          DateTime @default(now())
  metadata           String   @default("{}")

  @@index([agentId])
  @@index([userId])
  @@index([timestamp])
  @@map("consciousness_interactions")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String?
  name          String?
  provider      String?        @default("email")
  verified      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  lastLogin     DateTime?
  createdAgents CreatedAgent[]
  subscription  Subscription?
  userProfile   UserProfile?

  @@index([email])
  @@map("users")
}

model Subscription {
  id        String    @id @default(cuid())
  userId    String    @unique
  tier      String    @default("free")
  status    String    @default("active")
  features  String    @default("{}")
  createdAt DateTime  @default(now())
  expiresAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tier])
  @@index([status])
  @@map("subscriptions")
}

model MonicaContextualHelp {
  id              String    @id @default(cuid())
  pageUrl         String
  contextType     String
  tipId           String
  tipContent      String
  priority        String
  category        String
  timesShown      Int       @default(0)
  timesActedOn    Int       @default(0)
  averageRating   Float?
  successRate     Float     @default(0.0)
  variant         String?
  testGroup       String?
  version         String    @default("1.0")
  isActive        Boolean   @default(true)
  deprecatedAt    DateTime?
  averageViewTime Int       @default(0)
  bounceRate      Float     @default(0.0)
