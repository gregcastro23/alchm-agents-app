{
  "name": "planetary-agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "typecheck:errors": "tsc --noEmit 2>&1 | grep -E 'error TS' | wc -l",
    "typecheck:summary": "tsc --noEmit 2>&1 | grep -E 'error TS' | head -20",
    "typecheck:by-file": "tsc --noEmit 2>&1 | grep -E 'error TS' | cut -d'(' -f1 | sort | uniq -c | sort -nr",
    "typecheck:missing-properties": "tsc --noEmit 2>&1 | grep -E \"Property '.*' does not exist\"",
    "typecheck:type-mismatches": "tsc --noEmit 2>&1 | grep -E 'is not assignable to type'",
    "lint:typescript": "eslint . --ext .ts,.tsx --rule '@typescript-eslint/no-explicit-any: warn'",
    "lint:errors-only": "eslint . --ext .js,.jsx,.ts,.tsx --quiet",
    "check": "bun run lint && bun run format:check && bun run typecheck",
    "linting-campaign:start": "echo '🚀 Starting TypeScript Error Resolution Campaign' && bun run typecheck:errors",
    "linting-campaign:summary": "echo '📊 Error Summary:' && bun run typecheck:summary",
    "linting-campaign:by-file": "echo '📁 Errors by File:' && bun run typecheck:by-file",
    "linting-campaign:missing-props": "echo '🔍 Missing Properties:' && bun run typecheck:missing-properties | head -10",
    "linting-campaign:type-mismatches": "echo '🔄 Type Mismatches:' && bun run typecheck:type-mismatches | head -10",
    "linting-campaign:progress": "echo '📈 Current Progress:' && echo 'Total errors:' $(bun run typecheck:errors 2>/dev/null) && echo 'Starting: 1065' && echo 'Resolved:' $((1065 - $(bun run typecheck:errors 2>/dev/null))) && echo 'Remaining:' $(bun run typecheck:errors 2>/dev/null)",
    "linting-campaign:report": "node scripts/linting-campaign.js report",
    "linting-campaign:patterns": "node scripts/linting-campaign.js patterns",
    "test:chat": "bun run test/chat-system/run-tests.ts",
    "test:chat:unit": "vitest run test/chat-system/unit/ --config vitest.unit.config.ts",
    "test:chat:integration": "vitest run test/chat-system/integration/ --config vitest.unit.config.ts",
    "test:chat:performance": "vitest run test/chat-system/performance/",
    "test:chat:watch": "vitest test/chat-system/unit/ test/chat-system/integration/",
    "test:chat:coverage": "vitest run --coverage test/chat-system/",
    "test:historical": "vitest run test/chat-system/unit/historical-council-chat.test.tsx",
    "test:planetary": "vitest run test/chat-system/unit/planetary-wisdom-chat.test.tsx",
    "test:laboratory": "vitest run test/chat-system/unit/consciousness-laboratory-chat.test.tsx",
    "test:api": "vitest run test/chat-system/integration/unified-api.test.ts",
    "test:benchmark": "vitest run test/chat-system/performance/benchmark.test.ts",
    "test:chat:report": "bun run -e \"console.log(JSON.stringify(require('./test-results/latest-summary.json'), null, 2))\"",
    "test:chat:clean": "rm -rf test-results coverage .vitest",
    "test:ci:chat": "bun run test:chat:clean && bun run test:chat && bun run test:chat:report",
    "dev:enhanced": "concurrently \"bun run dev\" \"bun run db:studio\"",
    "dev:debug": "NODE_OPTIONS='--inspect' bun run dev",
    "typecheck:watch": "tsc --noEmit --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "db:studio": "npx prisma studio",
    "prisma:generate": "prisma generate --no-engine",
    "prepare": "is-ci || husky install",
    "rag:setup": "./scripts/setup-rag.sh",
    "rag:ingest": "bun run lib/llamaindex/ingestion-pipeline.ts",
    "rag:test": "curl -X POST http://localhost:3000/api/agents/semantic-search -H 'Content-Type: application/json' -d '{\"concept\": \"wisdom\", \"topK\": 3}'",
    "rag:test:unit": "vitest run test/rag/",
    "rag:test:watch": "vitest test/rag/",
    "verify-chromadb": "bun run scripts/verify-chromadb.ts",
    "verify-db": "bun run scripts/verify-database.ts",
    "test-rag": "bun run scripts/test-rag-e2e.ts",
    "benchmark-rag": "bun run scripts/benchmark-rag.ts",
    "chroma:docker": "docker run -p 8000:8000 chromadb/chroma",
    "sync:db": "bun run scripts/seed-historical-agents.ts",
    "sync:chromadb": "OPENAI_API_KEY=\"${OPENAI_API_KEY}\" CHROMADB_URL=http://localhost:8001 bun run lib/llamaindex/ingestion-pipeline.ts --force",
    "sync:all": "bun run scripts/sync-all-systems.ts",
    "sync:validate": "bun run scripts/validate-agent-sync.ts",
    "sync:clear-chroma": "bun run scripts/clear-chromadb.ts",
    "render:validate": "bun run scripts/validate-render-config.ts",
    "render:test-mcp": "bun run scripts/test-render-mcp.ts"
  },
