{
  "buildCommand": "yarn build",
  "installCommand": "pip3 install setuptools && yarn install",
  "framework": "nextjs",
  "functions": {
    "app/api/**/*.ts": {
      "memory": 2048,
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=60, stale-while-revalidate"
        }
      ]
    }
  ]
}
