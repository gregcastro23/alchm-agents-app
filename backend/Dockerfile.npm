# =============================================================================
# PLANETARY AGENTS BACKEND - NPM PRODUCTION DOCKERFILE
# =============================================================================

# Use official Node.js runtime as base image
FROM node:18-alpine

# Set working directory in container
WORKDIR /app

# Install curl for health checks
RUN apk add --no-cache curl dumb-init libc6-compat python3 make g++

# Create non-root user for security
RUN addgroup -g 1001 -S nodejs && \
    adduser -S backend -u 1001

# Copy package files
COPY package.json ./
# Copy package-lock.json if it exists
COPY package-lock.json* ./

# Install dependencies using npm
RUN npm ci --only=production && \
    npm cache clean --force && \
    rm -rf /tmp/* /var/cache/apk/*

# Copy source code
COPY . .

# Build the application
RUN npm run build

# Change ownership to non-root user
RUN chown -R backend:nodejs /app
USER backend

# Expose ports
EXPOSE 8000 8001

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8000/api/health || exit 1

# Use dumb-init to handle signals properly
ENTRYPOINT ["dumb-init", "--"]

# Start the application
CMD ["npm", "start"]

# =============================================================================
# BUILD INSTRUCTIONS
# =============================================================================

# To build and run locally:
# docker build -f Dockerfile.npm -t planetary-agents-backend-npm .
# docker run -p 8000:8000 -p 8001:8001 planetary-agents-backend-npm

# For production deployment:
# 1. Push to container registry (Docker Hub, GitHub Container Registry, etc.)
# 2. Configure Render to use the container image
# 3. Set environment variables in Render dashboard

# =============================================================================
# SECURITY FEATURES
# =============================================================================

# ✅ Non-root user for enhanced security
# ✅ Health checks for monitoring
# ✅ Signal handling with dumb-init
# ✅ Minimal Alpine Linux base image
# ✅ Production dependencies only
# ✅ Cache cleanup for smaller image size